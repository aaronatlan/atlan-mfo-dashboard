<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      alignment="CENTER"
      spacing="10"
      styleClass="auth-root">

    <Label styleClass="brand-mark" text="ATLAN" />
    <Label styleClass="brand-sub" text="MFO DASHBOARD" />

    <Region prefHeight="24" />

    <Label styleClass="field-label" text="IDENTIFIANT" maxWidth="Infinity" />
    <TextField fx:id="usernameField" promptText="identifiant" />

    <Label styleClass="field-label" text="MOT DE PASSE" maxWidth="Infinity" />
    <PasswordField fx:id="passwordField" promptText="mot de passe" onAction="#onLogin" />

    <Label fx:id="errorLabel" styleClass="error-label" maxWidth="Infinity" wrapText="true" />

    <Region prefHeight="8" />

    <Button text="Se connecter" onAction="#onLogin" defaultButton="true"
            styleClass="primary-button" maxWidth="Infinity" />
</VBox>

