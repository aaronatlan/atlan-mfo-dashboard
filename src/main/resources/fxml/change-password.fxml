<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      alignment="CENTER"
      spacing="10"
      styleClass="auth-root">

    <Label styleClass="brand-mark" text="ATLAN" />
    <Label styleClass="brand-sub" text="CHANGEMENT DE MOT DE PASSE" />

    <Region prefHeight="16" />

    <Label styleClass="help-text" wrapText="true" maxWidth="Infinity"
           text="Ce compte utilise un mot de passe temporaire. Choisissez un nouveau mot de passe (8 caractères minimum) pour continuer." />

    <Region prefHeight="8" />

    <Label styleClass="field-label" text="NOUVEAU MOT DE PASSE" maxWidth="Infinity" />
    <PasswordField fx:id="newPasswordField" promptText="nouveau mot de passe" />

    <Label styleClass="field-label" text="CONFIRMATION" maxWidth="Infinity" />
    <PasswordField fx:id="confirmPasswordField" promptText="confirmer" onAction="#onSubmit" />

    <Label fx:id="errorLabel" styleClass="error-label" maxWidth="Infinity" wrapText="true" />

    <Region prefHeight="8" />

    <Button text="Valider" onAction="#onSubmit" defaultButton="true"
            styleClass="primary-button" maxWidth="Infinity" />
</VBox>
